<settings>
    <category label="Playback">
        <setting id="use_inputstream" type="bool" label="Use inputstream.adaptive for playback" default="true" />
        <setting id="load_descriptions" type="bool" label="Load series and video descriptions (slower)" default="true" />
    </category>
    <category label="Log Notifications">
        <setting id="debug" type="bool" label="Enable debug logging" default="false" />
    </category>
    <category label="Cache">
        <setting id="clear_cache" type="action" label="Clear Cache" 
        action="RunPlugin(plugin://metalchris.video.nasaplus/?action=clear_cache)" />
    </category>
</settings>
