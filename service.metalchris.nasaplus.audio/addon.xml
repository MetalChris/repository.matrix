<addon id="service.metalchris.nasaplus.audio"
       name="Auto Audio Track 2 Selector"
       version="1.0.4"
       provider-name="MetalChris">
    
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.service" library="service.py" start="login" />

    <extension point="xbmc.addon.metadata">
        <summary>Automatically switches to second audio track for NASA+</summary>
        <description>Auto Audio Track 2 Selector for NASA+. Forces Kodi to select the second audio track after playback starts.</description>
        <platform>all</platform>
        <assets>
            <icon>resources/media/icon.png</icon>
            <fanart>resources/media/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
